    <!-- CHANGE SET 2: INSERIMENTO UTENTE ADMIN        -->
    <!-- ============================================= -->
    <!-- LE PASSWORD DI TUTTI GLI UTENTI CREATI SONO HASHATE DA GENERATEPASSWORDHASH -->
    <changeSet id="2" author="davide">
        <comment>
            Inserisce l'utente amministratore
        </comment>
        
        <insert tableName="utenti">
            <column name="username" value="admin"/>
            <column name="password" value="$2a$10$N9qo8uLOickgx2ZMRZoMy.MrZ7RZ2qJ3XqKX5X5K5X5K5X5K5X5K5"/>
            <column name="email" value="admin@example.com"/>
            <column name="telefono" value="1234567890"/>
            <column name="data_nascita" value="1990-01-01"/>
            <column name="ruolo" value="ADMIN"/>
        </insert>
        
        <rollback>
            <delete tableName="utenti">
                <where>username='admin'</where>
            </delete>
        </rollback>
    </changeSet>
    
